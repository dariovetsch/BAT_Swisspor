  <ids:info>
    <ids:title>DC_BAT_FS26_Swisspor</ids:title>
    <ids:version/>
    <ids:description>Integration von Bauprodukten in einen BIM-basierten LifeCycle Prozess</ids:description>
    <ids:author>dario.vetsch@stud.hslu.ch</ids:author>
    <ids:date>2026-06-03</ids:date>
    <ids:purpose>Mindestanforderungen (30-00) | Komplettsatz (30-07)</ids:purpose>
    <ids:milestone>Projektierung (30)</ids:milestone>
  </ids:info>
  <ids:specifications>
    <ids:specification name="OT001 Unterkonstruktion" ifcVersion="IFC4X3_ADD2">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
